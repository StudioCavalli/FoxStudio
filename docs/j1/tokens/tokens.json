{
  "$description": "FoxStudio design tokens — DTCG-style format. Source of truth for all color/typo/spacing/motion decisions. Consumed by Tailwind v4 (@theme) and Figma (via Token Studio plugin).",

  "color": {
    "$description": "Strict monochrome palette. Dark mode is default; light mode is the alternative. No accent color is permanent — accents are project-specific and live only on /works/[slug].",

    "bg": {
      "primary": {
        "$value": "#0A0A0A",
        "$type": "color",
        "$description": "Default background (dark mode default)."
      },
      "secondary": {
        "$value": "#141414",
        "$type": "color",
        "$description": "Cards, alternate sections (dark)."
      },
      "tertiary": { "$value": "#1F1F1F", "$type": "color", "$description": "Inset blocks (dark)." }
    },
    "fg": {
      "primary": {
        "$value": "#F4F4F4",
        "$type": "color",
        "$description": "Main text (dark mode)."
      },
      "secondary": {
        "$value": "#A0A0A0",
        "$type": "color",
        "$description": "Metadata, mono labels (dark)."
      },
      "tertiary": {
        "$value": "#666666",
        "$type": "color",
        "$description": "Disabled / faded (dark)."
      }
    },
    "border": {
      "default": {
        "$value": "#262626",
        "$type": "color",
        "$description": "Section dividers, grid lines (dark)."
      },
      "strong": {
        "$value": "#404040",
        "$type": "color",
        "$description": "Emphasized borders (dark)."
      }
    },
    "focus": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Focus ring color (dark mode)."
    },

    "light": {
      "$description": "Light-mode overrides. Same token names, inverted values.",
      "bg": {
        "primary": { "$value": "#FFFFFF", "$type": "color" },
        "secondary": { "$value": "#F4F4F4", "$type": "color" },
        "tertiary": { "$value": "#EAEAEA", "$type": "color" }
      },
      "fg": {
        "primary": { "$value": "#0A0A0A", "$type": "color" },
        "secondary": { "$value": "#666666", "$type": "color" },
        "tertiary": { "$value": "#999999", "$type": "color" }
      },
      "border": {
        "default": { "$value": "#E5E5E5", "$type": "color" },
        "strong": { "$value": "#CCCCCC", "$type": "color" }
      },
      "focus": { "$value": "#0A0A0A", "$type": "color" }
    }
  },

  "font": {
    "family": {
      "display": {
        "$value": "'PP Neue Montreal', 'Inter Tight', system-ui, sans-serif",
        "$type": "fontFamily",
        "$description": "Headings XXL. PP Neue Montreal preferred (license to acquire); fallback to Inter Tight."
      },
      "body": {
        "$value": "'Geist Sans', 'Inter', system-ui, sans-serif",
        "$type": "fontFamily",
        "$description": "Body, UI."
      },
      "mono": {
        "$value": "'Geist Mono', 'JetBrains Mono', ui-monospace, monospace",
        "$type": "fontFamily",
        "$description": "Metadata, labels, code."
      }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "$description": "Mobile-first; desktop overrides at lg breakpoint.",
      "mono-s": { "$value": "12px", "$type": "dimension" },
      "mono-m": { "$value": "13px", "$type": "dimension" },
      "body": { "$value": "16px", "$type": "dimension" },
      "body-l": { "$value": "18px", "$type": "dimension" },
      "heading": { "$value": "24px", "$type": "dimension", "desktop": "32px" },
      "display-m": { "$value": "36px", "$type": "dimension", "desktop": "64px" },
      "display-l": { "$value": "48px", "$type": "dimension", "desktop": "96px" },
      "display-xl": { "$value": "64px", "$type": "dimension", "desktop": "160px" }
    },
    "lineHeight": {
      "tight": { "$value": 1.0, "$type": "number", "$description": "Display sizes." },
      "snug": { "$value": 1.15, "$type": "number", "$description": "Headings." },
      "normal": { "$value": 1.5, "$type": "number", "$description": "Body." },
      "relaxed": { "$value": 1.7, "$type": "number", "$description": "Long-form (journal)." }
    },
    "letterSpacing": {
      "display": {
        "$value": "-0.02em",
        "$type": "dimension",
        "$description": "Tight tracking on display sizes."
      },
      "normal": { "$value": "0", "$type": "dimension" },
      "mono": {
        "$value": "0.04em",
        "$type": "dimension",
        "$description": "Slight tracking on mono labels."
      }
    }
  },

  "spacing": {
    "$description": "8px scale. All spacings should be multiples of 4 minimum.",
    "0": { "$value": "0", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "24px", "$type": "dimension" },
    "6": { "$value": "32px", "$type": "dimension" },
    "7": { "$value": "48px", "$type": "dimension" },
    "8": { "$value": "64px", "$type": "dimension" },
    "9": { "$value": "96px", "$type": "dimension" },
    "10": { "$value": "128px", "$type": "dimension" },
    "11": { "$value": "192px", "$type": "dimension" },
    "12": { "$value": "256px", "$type": "dimension" }
  },

  "radius": {
    "$description": "Volontairement très peu de radius — DA brutaliste.",
    "none": { "$value": "0", "$type": "dimension" },
    "xs": { "$value": "2px", "$type": "dimension", "$description": "Inputs, mono badges only." },
    "sm": { "$value": "4px", "$type": "dimension", "$description": "Cards rares." },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Status dots only." }
  },

  "border": {
    "width": {
      "0": { "$value": "0", "$type": "dimension" },
      "1": {
        "$value": "1px",
        "$type": "dimension",
        "$description": "Default — grid lines, dividers, card borders."
      },
      "2": { "$value": "2px", "$type": "dimension", "$description": "Focus rings." }
    }
  },

  "grid": {
    "columns": {
      "desktop": { "$value": 12, "$type": "number" },
      "tablet": { "$value": 8, "$type": "number" },
      "mobile": { "$value": 4, "$type": "number" }
    },
    "gutter": {
      "desktop": { "$value": "24px", "$type": "dimension" },
      "tablet": { "$value": "20px", "$type": "dimension" },
      "mobile": { "$value": "16px", "$type": "dimension" }
    },
    "margin": {
      "desktop": { "$value": "48px", "$type": "dimension" },
      "tablet": { "$value": "32px", "$type": "dimension" },
      "mobile": { "$value": "20px", "$type": "dimension" }
    },
    "maxWidth": {
      "$value": "1440px",
      "$type": "dimension",
      "$description": "Max content width on very large screens."
    }
  },

  "breakpoint": {
    "sm": { "$value": "640px", "$type": "dimension" },
    "md": { "$value": "768px", "$type": "dimension" },
    "lg": { "$value": "1024px", "$type": "dimension" },
    "xl": { "$value": "1280px", "$type": "dimension" },
    "2xl": { "$value": "1536px", "$type": "dimension" }
  },

  "motion": {
    "$description": "All animations > 200ms must be disabled when prefers-reduced-motion is set.",
    "duration": {
      "instant": { "$value": "100ms", "$type": "duration" },
      "fast": {
        "$value": "150ms",
        "$type": "duration",
        "$description": "Hover states, button feedback."
      },
      "base": { "$value": "300ms", "$type": "duration", "$description": "Default transitions." },
      "slow": { "$value": "600ms", "$type": "duration", "$description": "Reveal text on scroll." },
      "page": { "$value": "400ms", "$type": "duration", "$description": "View Transitions." }
    },
    "easing": {
      "linear": { "$value": "linear", "$type": "cubicBezier" },
      "default": {
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
        "$type": "cubicBezier",
        "$description": "Default ease-in-out (Material)."
      },
      "reveal": {
        "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "$type": "cubicBezier",
        "$description": "Expressive reveal (out-expo-ish)."
      },
      "page": {
        "$value": "cubic-bezier(0.83, 0, 0.17, 1)",
        "$type": "cubicBezier",
        "$description": "Page transitions."
      }
    }
  },

  "shadow": {
    "$description": "Shadows used very sparingly — N&B brutaliste prefers borders to shadows.",
    "none": { "$value": "none", "$type": "shadow" },
    "subtle": {
      "$value": {
        "color": "#00000033",
        "offsetX": "0",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0"
      },
      "$type": "shadow",
      "$description": "Hover lift only."
    }
  },

  "z": {
    "base": { "$value": 0, "$type": "number" },
    "raised": { "$value": 10, "$type": "number" },
    "sticky": { "$value": 20, "$type": "number", "$description": "Header sticky." },
    "overlay": { "$value": 30, "$type": "number" },
    "modal": { "$value": 40, "$type": "number" },
    "toast": { "$value": 50, "$type": "number" },
    "cursor": { "$value": 60, "$type": "number", "$description": "Custom cursor." }
  }
}
