# ──────────────────────────────────────────────────────────
# FoxStudio environment template
# Copy to .env.local for local dev. Configure in Vercel for prod.
# ──────────────────────────────────────────────────────────

# Payload CMS — required when running the admin & DB-backed pages.
# Local dev: a free Neon project works fine.
# Prod: Vercel Postgres or Neon serverless.
DATABASE_URL=postgres://user:password@host:5432/foxstudio

# Payload secret — used to sign JWTs and encrypt session data.
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=change-me-with-openssl-rand-hex-32

# ──────────────────────────────────────────────────────────
# Cloudflare R2 — media storage (S3-compatible).
# When all four are set, Payload uploads media to R2.
# When unset, Payload writes to public/uploads/ (local fallback).
# ──────────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=foxstudio-media
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto

# ──────────────────────────────────────────────────────────
# Site URL — used by Payload for absolute URLs in admin and emails.
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
