# ──────────────────────────────────────────────────────────
# FoxStudio environment template
# Copy to .env.local for local dev. Configure in Vercel for prod.
# ──────────────────────────────────────────────────────────

# Postgres (Neon — non-pooled URL for Payload migrations & long-lived queries)
# Local + prod share the same provider. Vercel injects this automatically
# once Neon is connected via the Vercel Storage marketplace.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Payload secret — used to sign JWTs and encrypt session data.
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=change-me-with-openssl-rand-hex-32

# ──────────────────────────────────────────────────────────
# Vercel Blob — media storage.
# Token from: Vercel → Storage → <your blob store> → .env.local tab.
# When set, Payload uploads media to Vercel Blob.
# When unset, Payload writes to public/uploads/ (local fallback).
# ──────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ──────────────────────────────────────────────────────────
# Site URL — used by Payload for absolute URLs in admin and emails.
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
