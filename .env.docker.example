# ──────────────────────────────────────────────────────────
# FoxStudio — local dev environment (Docker)
# Copy to .env.local — these values match docker-compose.yml.
# ──────────────────────────────────────────────────────────

# Postgres (Docker container exposed on localhost:5432)
DATABASE_URL=postgresql://foxstudio:foxstudio@localhost:5432/foxstudio

# Payload secret — fine for local dev, generate a real one for prod with `openssl rand -hex 32`
PAYLOAD_SECRET=foxstudio-dev-secret-not-for-prod

# MinIO acts as a local R2 stand-in (S3-compatible).
# These match the credentials defined in docker-compose.yml.
R2_ACCESS_KEY_ID=foxstudio
R2_SECRET_ACCESS_KEY=foxstudio-dev-secret
R2_BUCKET=foxstudio-media
R2_ENDPOINT=http://localhost:9000
R2_REGION=auto

NEXT_PUBLIC_SITE_URL=http://localhost:3000
