{
  "name": "foxstudio",
  "version": "0.1.0",
  "private": true,
  "description": "FoxStudio — R&D lab of FoxCase. Showcase site.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "payload": "PAYLOAD_CONFIG_PATH=payload.config.ts payload",
    "payload:migrate": "PAYLOAD_CONFIG_PATH=payload.config.ts payload migrate",
    "payload:types": "PAYLOAD_CONFIG_PATH=payload.config.ts payload generate:types",
    "payload:importmap": "PAYLOAD_CONFIG_PATH=payload.config.ts payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-s3": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "geist": "^1.3.1",
    "graphql": "^16.13.2",
    "lenis": "^1.3.23",
    "next": "^15.5.0",
    "payload": "^3.84.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
